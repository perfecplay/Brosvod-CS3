+    }
+    
+    // Bulunamazsa kaynak kodun bir kısmını logla
+    Log.d("KLT", "First 500 chars of source: ${sourceCode.take(500)}")
+    Log.d("KLT", "No subtitle URL found in source code")
+    return null
